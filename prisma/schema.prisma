generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum RequirementType {
  GIVE
  ASK
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DirectoryUser {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  role          Role      @default(USER)
  isPremium     Boolean   @default(false)
  premiumExpiresAt DateTime?
  image         String?
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       BusinessProfile?
  messagesSent  Message[] @relation("SentMessages")
  messagesRecv  Message[] @relation("ReceivedMessages")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user DirectoryUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         DirectoryUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
  id               String        @id @default(cuid())
  userId           String        @unique
  user             DirectoryUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName      String
  type             String
  description      String?       @db.Text
  location         String?
  verified         Boolean       @default(false)
  ownerName        String?
  address          String?
  city             String?
  state            String?
  country          String?
  category         String?
  website          String?
  contactPerson    String?
  yearsActive      Int?
  turnover         String?
  scale            String?
  keyMarkets       String[]
  certifications   String[]
  productsServices String?
  buyingProducts   String[]
  sellingProducts  String[]
  logoUrl          String?
  bannerUrl        String?

  requirements Requirement[]
  asksMade     Match[]       @relation("Asker")
  givesMade    Match[]       @relation("Giver")
}

model Requirement {
  id          String          @id @default(cuid())
  profileId   String
  profile     BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type        RequirementType
  category    String
  description String          @db.Text
  tags        String[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Match {
  id        String          @id @default(cuid())
  askerId   String
  asker     BusinessProfile @relation("Asker", fields: [askerId], references: [id], onDelete: Cascade)
  giverId   String
  giver     BusinessProfile @relation("Giver", fields: [giverId], references: [id], onDelete: Cascade)
  score     Float
  status    MatchStatus     @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Message {
  id         String        @id @default(cuid())
  senderId   String
  sender     DirectoryUser @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   DirectoryUser @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String        @db.Text
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
}
